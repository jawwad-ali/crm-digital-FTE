# OpenAI — required for agent LLM and embedding generation
OPENAI_API_KEY=sk-your-key-here

# Agent model — used by the Customer Success Agent (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# Database (Neon PostgreSQL) — must have pgvector extension enabled
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require

# Kafka (Upstash) — future feature, not required for agent
# KAFKA_BOOTSTRAP_SERVERS=
# KAFKA_USERNAME=
# KAFKA_PASSWORD=
